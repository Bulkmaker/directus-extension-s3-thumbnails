{
  "name": "directus-extension-s3-thumbnails",
  "version": "0.1.0-alpha.1",
  "description": "Auto-generate image thumbnails on upload and store them in S3 for static site generation. Serve images directly from S3 without Directus.",
  "icon": "photo_size_select_large",
  "keywords": [
    "directus",
    "directus-extension",
    "thumbnails",
    "images",
    "s3",
    "cdn",
    "static-site",
    "jamstack"
  ],
  "author": "Bulkmaker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bulkmaker/directus-extension-s3-thumbnails"
  },
  "type": "module",
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "hook",
        "name": "thumbnails-hook",
        "source": "src/hooks/index.ts"
      },
      {
        "type": "endpoint",
        "name": "thumbnails",
        "source": "src/endpoints/index.ts"
      }
    ],
    "host": "^10.0.0 || ^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^12.0.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  }
}
